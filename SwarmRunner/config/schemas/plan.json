{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DAGPlan",
  "description": "A directed acyclic graph of execution steps with dependency edges",
  "type": "object",
  "required": ["plan_id", "goal", "steps"],
  "properties": {
    "plan_id": {
      "type": "string",
      "description": "Unique identifier for this plan"
    },
    "goal": {
      "type": "string",
      "description": "High-level objective this plan achieves"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step_id", "action", "description"],
        "properties": {
          "step_id": {
            "type": "string",
            "description": "Unique step identifier"
          },
          "action": {
            "type": "string",
            "description": "The action type to execute",
            "enum": ["search", "extract", "analyze", "code", "verify", "synthesize", "delegate"]
          },
          "description": {
            "type": "string",
            "description": "What this step does"
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Step IDs that must complete before this step"
          },
          "inputs": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Named inputs for this step"
          },
          "output_key": {
            "type": "string",
            "description": "Key name for this step's output in the context"
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "estimated_steps": { "type": "integer" },
        "complexity": { "type": "string", "enum": ["low", "medium", "high"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
