{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Verification",
  "description": "Cross-reference verification of claims against multiple sources",
  "type": "object",
  "required": ["claim", "verdict", "sources_checked"],
  "properties": {
    "claim": {
      "type": "string",
      "description": "The factual claim being verified"
    },
    "verdict": {
      "type": "string",
      "enum": ["confirmed", "contradicted", "partially_confirmed", "unverifiable", "insufficient_evidence"],
      "description": "Overall verification result"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence in the verdict"
    },
    "sources_checked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source", "stance"],
        "properties": {
          "source": {
            "type": "string",
            "description": "Source identifier or URL"
          },
          "stance": {
            "type": "string",
            "enum": ["supports", "contradicts", "neutral", "irrelevant"],
            "description": "How this source relates to the claim"
          },
          "excerpt": {
            "type": "string",
            "description": "Relevant excerpt from the source"
          },
          "reliability": {
            "type": "string",
            "enum": ["high", "medium", "low", "unknown"],
            "description": "Estimated reliability of this source"
          }
        },
        "additionalProperties": false
      }
    },
    "reasoning": {
      "type": "string",
      "description": "Explanation of how the verdict was reached"
    }
  },
  "additionalProperties": false
}
