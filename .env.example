# ─── Base Model ───
SWARM_BASE_MODEL=Qwen/Qwen3.5-0.8B-GPTQ-Int4
HF_TOKEN=

# ─── SwarmRunner (vLLM + Router) ───
SWARM_VLLM_PORT=8000
SWARM_RUNNER_PORT=8100
SWARM_MAX_LORAS=64
SWARM_MAX_CPU_LORAS=128
SWARM_MAX_LORA_RANK=64
SWARM_GPU_MEMORY_UTIL=0.90
SWARM_MAX_MODEL_LEN=8192
SWARM_GUIDED_BACKEND=xgrammar

# ─── SwarmExecutor ───
SWARM_EXECUTOR_PORT=8500
MAX_PARALLEL_AGENTS=50
MAX_AGENT_STEPS=10

# ─── External Services ───
HIVEMIND_URL=http://host.docker.internal:8100
CODEGATE_URL=http://host.docker.internal:9212
CODEGATE_API_KEY=proxy-local-key
TEACHER_MODEL=claude-sonnet-4-20250514

# ─── Training (SwarmTrainer — run separately) ───
BASE_MODEL=Qwen/Qwen3.5-0.8B
CUDA_VISIBLE_DEVICES=0
WANDB_API_KEY=
